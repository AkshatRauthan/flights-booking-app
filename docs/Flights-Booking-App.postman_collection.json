			"type": "string"
		}
	],
	"item": [
		{
			"name": "Auth",
			"description": "Authentication endpoints — signup and signin via the API Gateway.",
			"item": [
				{
					"name": "Signup",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/signup",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "signup"]
						},
						"description": "Register a new user account. Returns a JWT token on success.\n\nOptional fields:\n- `isDatabaseAdmin` (boolean) — mark as system admin (internal use)\n- `isAirlineAdmin` (boolean) — mark as airline admin (internal use)"
					},
					"response": []
				},
				{
					"name": "Signin",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"user@example.com\",\n    \"password\": \"password123\"\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/auth/signin",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "auth", "signin"]
						},
						"description": "Authenticate an existing user. Returns a JWT token on success."
					},
					"response": []
				},
				{
					"name": "Internal Signup (Service-to-Service)",
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							},
							{
								"key": "x-service-token",
								"value": "{{serviceToken}}",
								"description": "Internal service authentication token"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n    \"email\": \"airline-admin@example.com\",\n    \"password\": \"securepassword\",\n    \"isAirlineAdmin\": true\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/v1/internal/auth/signup",
							"host": ["{{baseUrl}}"],
							"path": ["api", "v1", "internal", "auth", "signup"]
						},
						"description": "Internal endpoint for service-to-service user creation (e.g., creating airline admin accounts from Flights Creation Service). Requires a valid internal service token."
					},
					"response": []
				}
			]
		},
