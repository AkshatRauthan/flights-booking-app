# Server
PORT=3003
NODE_ENV=development
LOG_LEVEL=info

# Service Identity
SERVICE_NAME=flight-creation-service
SERVICE_ENCRYPTION_KEY=your_64_char_hex_key_here
SERVICE_TOKEN_EXPIRY_IN_SECONDS=300

# Authentication
SALT_ROUNDS=10
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRY=24h

# Service URLs
FLIGHT_CREATION_SERVICE=http://localhost:3003
FLIGHT_SEARCHING_SERVICE=http://localhost:3004
FLIGHT_BOOKING_SERVICE=http://localhost:3002
API_GATEWAY=http://localhost:3001
NOTIFICATION_SERVICE=http://localhost:3005

# RabbitMQ
RABBITMQ_HOST=localhost
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest
AIRLINE_ADMIN_REQ_QUEUE=airline-admin-req-queue
AIRLINE_ADMIN_RES_QUEUE=airline-admin-res-queue

# Database
DB_USERNAME=root
DB_PASSWORD=your_db_password
DB_NAME=flights
DB_HOST=127.0.0.1
DB_DIALECT=mysql
