# Database
DB_ROOT_PASSWORD=rootpassword
DB_USERNAME=flights_user
DB_PASSWORD=flights_password

# RabbitMQ
RABBITMQ_USERNAME=guest
RABBITMQ_PASSWORD=guest

# JWT
JWT_SECRET=your-jwt-secret-change-in-production
JWT_EXPIRY=1h
SALT_ROUNDS=10

# Service Auth
SERVICE_SECRET=your-service-secret-change-in-production
SERVICE_TOKEN_EXPIRY=300

# Gmail (for Notifications Service)
GMAIL_EMAIL=your-email@gmail.com
GMAIL_APP_PASSWORD=your-gmail-app-password

# Ports (optional overrides)
API_GATEWAY_PORT=3001
BOOKING_SERVICE_PORT=3002
CREATION_SERVICE_PORT=3003
SEARCHING_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
